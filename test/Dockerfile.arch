FROM archlinux:base-devel

# Keep package list current and install test dependencies
RUN pacman -Syu --noconfirm \
    && pacman -S --needed --noconfirm \
        sudo \
        curl \
        libnewt \
        git \
    && pacman -Scc --noconfirm

# Create a non-root user with passwordless sudo
RUN useradd -m -G wheel testuser \
    && echo '%wheel ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers

USER testuser
WORKDIR /home/testuser

# Copy the script into the image
COPY --chown=testuser:testuser install.sh /home/testuser/install.sh
RUN chmod +x /home/testuser/install.sh

ENTRYPOINT ["/bin/bash"]
